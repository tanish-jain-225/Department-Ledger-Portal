rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function authEmail() {
      return signedIn() ? request.auth.token.email : null;
    }
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isStaff() {
      return userExists() && userData().role in ['faculty', 'admin'];
    }
    function isAdmin() {
      return userExists() && userData().role == 'admin';
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    function selfUserAllowedUpdateKeys() {
      // Only allow end-users to edit non-privileged profile fields.
      // Everything else (role, verification, status, timestamps, etc.) is staff/admin controlled.
      return [
        'name',
        'phone',
        'address',
        'dob',
        'gender',
        'linkedin',
        'github',
        'alumni',
        // Allow client to bump updatedAt for UI freshness.
        'updatedAt'
      ];
    }
    function selfUserUpdateIsSafe() {
      // Prevent privilege escalation by restricting *what* fields can change.
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      // Case A: regular profile updates by the owner (plus optional updatedAt).
      let profileOk = changed.hasOnly(selfUserAllowedUpdateKeys())
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email
        && request.resource.data.status == resource.data.status
        && request.resource.data.facultyVerification == resource.data.facultyVerification
        && request.resource.data.verificationMethod == resource.data.verificationMethod
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.lastLogin == resource.data.lastLogin;

      // Case B: allow the app to record lastLogin on sign-in (only that field).
      let lastLoginOk = changed.hasOnly(['lastLogin'])
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email
        && request.resource.data.status == resource.data.status
        && request.resource.data.facultyVerification == resource.data.facultyVerification
        && request.resource.data.verificationMethod == resource.data.verificationMethod
        && request.resource.data.createdAt == resource.data.createdAt;

      return profileOk || lastLoginOk;
    }

    match /users/{uid} {
      allow read: if signedIn() && (isOwner(uid) || isStaff());
      allow create: if signedIn() && isOwner(uid)
        && request.resource.data.role == ''
        // Ensure the profile being created matches the authenticated email.
        && request.resource.data.email == authEmail();
      allow update: if isAdmin() || (isOwner(uid) && selfUserUpdateIsSafe());
      allow delete: if isAdmin();
    }

    match /facultyWhitelist/{emailId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /roleRequests/{id} {
      allow read: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /dataDeletionRequests/{id} {
      allow read: if isAdmin();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if signedIn() && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /notifications/{id} {
      allow read: if signedIn() && resource.data.recipientUid == request.auth.uid;
      allow create: if signedIn() && isStaff();
      allow update: if signedIn() && resource.data.recipientUid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /academicRecords/{id} {
      allow read: if signedIn() && (resource.data.studentUid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.studentUid == request.auth.uid || isAdmin());
    }

    match /activities/{id} {
      allow read: if signedIn() && (resource.data.studentUid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.studentUid == request.auth.uid || isAdmin());
    }

    match /achievements/{id} {
      allow read: if signedIn() && (resource.data.studentUid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.studentUid == request.auth.uid || isAdmin());
    }

    match /placements/{id} {
      allow read: if signedIn() && (resource.data.studentUid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.studentUid == request.auth.uid || isAdmin());
    }

    match /certificates/{id} {
      allow read: if signedIn() && (resource.data.studentUid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.studentUid == request.auth.uid || isAdmin());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
