rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStaff() {
      return isAuth() && (getRole() == 'faculty' || getRole() == 'admin');
    }

    function isAdmin() {
      return isAuth() && getRole() == 'admin';
    }

    function isAllowedAuditAction(action) {
      return action == 'user_role_assigned' ||
        action == 'user_deleted' ||
        action == 'profile_updated' ||
        action == 'deletionRequests_created' ||
        action == 'deletionRequests_updated' ||
        action == 'deletionRequests_deleted' ||
        action == 'academicRecords_created' ||
        action == 'academicRecords_updated' ||
        action == 'academicRecords_deleted' ||
        action == 'achievements_created' ||
        action == 'achievements_updated' ||
        action == 'achievements_deleted' ||
        action == 'activities_created' ||
        action == 'activities_updated' ||
        action == 'activities_deleted' ||
        action == 'placements_created' ||
        action == 'placements_updated' ||
        action == 'placements_deleted' ||
        action == 'projects_created' ||
        action == 'projects_updated' ||
        action == 'projects_deleted' ||
        action == 'skills_created' ||
        action == 'skills_updated' ||
        action == 'skills_deleted' ||
        action == 'aiReports_created' ||
        action == 'aiReports_updated' ||
        action == 'aiReports_deleted';
    }

    // ── users ─────────────────────────────────────────────────────────────
    // READ: Only the user themselves, or staff (faculty/admin).
    match /users/{userId} {
      // Privacy boundary:
      // - users can read their own profile
      // - admins can read any profile
      // - staff can read student/faculty profiles for operational workflows
      allow read:   if isAuth() && (
        uid() == userId ||
        isAdmin() ||
        (isStaff() && (resource.data.role == 'student' || resource.data.role == 'faculty'))
      );
      allow create: if isAuth() && uid() == userId;
      allow update: if isAuth() && (uid() == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Student ledger collections ────────────────────────────────────────
    // Shared rules for: academicRecords, achievements, activities,
    //                   placements, projects, skills, aiReports

    match /academicRecords/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /achievements/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /activities/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /placements/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /projects/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /skills/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /aiReports/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /uploadedDocuments/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    // ── roleRequests ──────────────────────────────────────────────────────
    match /roleRequests/{docId} {
      allow read:   if isAuth() && (resource.data.uid == uid() || isAdmin());
      allow create: if isAuth() && request.resource.data.uid == uid();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── deletionRequests ──────────────────────────────────────────────────
    match /deletionRequests/{docId} {
      allow read:   if isAuth() && (resource.data.uid == uid() || isAdmin());
      allow create: if isAuth() && request.resource.data.uid == uid();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── notifications ─────────────────────────────────────────────────────
    match /notifications/{docId} {
      allow read:   if isAuth() && resource.data.userUid == uid();
      // Users may create their own notifications; admins may create for any recipient.
      allow create: if isAuth() && (request.resource.data.userUid == uid() || isAdmin());
      allow update: if isAuth() && (resource.data.userUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.userUid == uid() || isAdmin());
    }

    // ── auditLogs ─────────────────────────────────────────────────────────
    match /auditLogs/{docId} {
      allow read:   if isAdmin();
      allow create: if isAuth() && request.resource.data.actorUid == uid() && (
        // Admin actions are allowed for governance workflows
        (isAdmin() && isAllowedAuditAction(request.resource.data.action)) ||
        // Non-admin users can only write self-profile update audit entries
        (!isAdmin() &&
          request.resource.data.action == 'profile_updated' &&
          request.resource.data.targetUid == uid())
      );
      allow update: if false;
      allow delete: if false;
    }

  }
}
