rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function ownUser() {
      return signedIn() && request.auth.uid == request.auth.uid;
    }
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isStaff() {
      return userExists() && userData().role in ['faculty', 'admin'];
    }
    function isAdmin() {
      return userExists() && userData().role == 'admin';
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if signedIn() && (isOwner(uid) || isStaff());
      allow create: if signedIn() && isOwner(uid)
        && request.resource.data.role == '';
      allow update: if isAdmin()
        || (isOwner(uid)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isAdmin();
    }

    match /facultyWhitelist/{emailId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /roleRequests/{id} {
      allow read: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /dataDeletionRequests/{id} {
      allow read: if isAdmin();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /auditLogs/{id} {
      allow read: if isAdmin();
      allow create: if signedIn() && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /notifications/{id} {
      allow read: if signedIn() && resource.data.recipientUid == request.auth.uid;
      allow create: if signedIn() && isStaff();
      allow update: if signedIn() && resource.data.recipientUid == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /academicRecords/{id} {
      allow read: if signedIn() && (resource.data.studentUid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.studentUid == request.auth.uid || isAdmin());
    }

    match /activities/{id} {
      allow read: if signedIn() && (resource.data.studentUid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.studentUid == request.auth.uid || isAdmin());
    }

    match /achievements/{id} {
      allow read: if signedIn() && (resource.data.studentUid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.studentUid == request.auth.uid || isAdmin());
    }

    match /placements/{id} {
      allow read: if signedIn() && (resource.data.studentUid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.studentUid == request.auth.uid || isAdmin());
    }

    match /certificates/{id} {
      allow read: if signedIn() && (resource.data.studentUid == request.auth.uid || isStaff());
      allow create: if signedIn() && request.resource.data.studentUid == request.auth.uid;
      allow update, delete: if signedIn() && (resource.data.studentUid == request.auth.uid || isAdmin());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
