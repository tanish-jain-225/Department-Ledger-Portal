rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStaff() {
      return isAuth() && (getRole() == 'faculty' || getRole() == 'admin');
    }

    function isAdmin() {
      return isAuth() && getRole() == 'admin';
    }

    // ── users ─────────────────────────────────────────────────────────────
    // READ: Only the user themselves, or staff (faculty/admin).
    match /users/{userId} {
      allow read:   if isAuth();
      allow create: if isAuth() && uid() == userId;
      allow update: if isAuth() && (uid() == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Student ledger collections ────────────────────────────────────────
    // Shared rules for: academicRecords, achievements, activities,
    //                   placements, projects, skills, aiReports

    match /academicRecords/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /achievements/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /activities/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /placements/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /projects/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /skills/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /aiReports/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    match /uploadedDocuments/{docId} {
      allow read:   if isAuth() && (resource.data.studentUid == uid() || isStaff());
      allow create: if isAuth() && request.resource.data.studentUid == uid();
      allow update: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.studentUid == uid() || isAdmin());
    }

    // ── roleRequests ──────────────────────────────────────────────────────
    match /roleRequests/{docId} {
      allow read:   if isAuth() && (resource.data.uid == uid() || isAdmin());
      allow create: if isAuth() && request.resource.data.uid == uid();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── deletionRequests ──────────────────────────────────────────────────
    match /deletionRequests/{docId} {
      allow read:   if isAuth() && (resource.data.uid == uid() || isAdmin());
      allow create: if isAuth() && request.resource.data.uid == uid();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── notifications ─────────────────────────────────────────────────────
    match /notifications/{docId} {
      allow read:   if isAuth() && resource.data.userUid == uid();
      allow create: if isAuth() && request.resource.data.userUid == uid(); 
      allow update: if isAuth() && (resource.data.userUid == uid() || isAdmin());
      allow delete: if isAuth() && (resource.data.userUid == uid() || isAdmin());
    }

    // ── auditLogs ─────────────────────────────────────────────────────────
    match /auditLogs/{docId} {
      allow read:   if isAdmin();
      allow create: if isAuth() && request.resource.data.actorUid == uid();
      allow update: if false;
      allow delete: if false;
    }

  }
}
