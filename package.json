    "build": "next build",
    "start": "next start",
    "lint": "eslint --config eslint.config.mjs . --ext .js,.jsx,.mjs",
    "test": "jest --no-coverage",
    "test:e2e": "playwright test --config=playwright.config.mjs"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1"
  },
  "dependencies": {
